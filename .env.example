# TOTLI HOLVA - Environment Variables
# Bu faylni .env nomiga nusxalang va qiymatlarni to'ldiring:
# copy .env.example .env

# ========== XAVFSIZLIK (majburiy production uchun) ==========
# Session va token shifrlash uchun. Yangi kalit: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# Birinchi marta admin yaratishda ishlatiladigan parol (create_admin.py, init_data.py).
# Production da albatta o'zgartiring!
# ADMIN_DEFAULT_PASSWORD=your-secure-admin-password

# Test skriptlari uchun (test_login.py, tekshirchi.py va boshqalar). Ixtiyoriy.
# TEST_ADMIN_PASSWORD=admin123

# Production rejimi (1/true/yes bo'lsa SECRET_KEY default bo'lishi mumkin emas)
# PRODUCTION=0

# HTTPS (cookie secure uchun, reverse proxy orqali)
# HTTPS=1

# ========== XARITA API ==========
# Yandex Maps: https://developer.tech.yandex.ru/ (ixtiyoriy - xarita ishlashi uchun)
# YANDEX_MAPS_API_KEY=096da66c-342b-4bab-80cd-3b44b851429c

# Google Maps (MAP_PROVIDER=google bo'lsa)
# GOOGLE_MAPS_API_KEY=

# ========== MA'LUMOTLAR BAZASI ==========
# SQLite default. PostgreSQL uchun:
# DATABASE_URL=postgresql://user:pass@localhost:5432/totli_holva
