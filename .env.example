# TOTLI HOLVA - Environment Variables
# Bu faylni .env nomiga nusxalang va qiymatlarni to'ldiring:
#   copy .env.example .env

# ========== XAVFSIZLIK (majburiy production uchun) ==========
# Session va token shifrlash uchun. Yangi kalit:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# Production rejimi (1/true/yes bo'lsa default SECRET_KEY raddetilenadi)
# PRODUCTION=0

# Development rejimi — uvicorn auto-reload (faqat local). Production da 0 qoldiring!
# DEV_MODE=0

# HTTPS (cookie secure flag uchun, reverse proxy orqali)
# HTTPS=1

# Session muddati (kun). Default 7 kun.
# Mobil tokenlar uchun: qisqaroq = xavfsizroq, lekin tez-tez login kerak.
# SESSION_MAX_AGE_DAYS=7

# Agent legacy login (phone-as-password) o'chirish
# 1/true/yes bo'lsa — phone=password login rad qilinadi (faqat PIN/bcrypt)
# Mobil ilovalar barchasida PIN o'rnatilgandan keyin yoqing.
# AGENT_LEGACY_LOGIN_DISABLED=0

# ===== TELEGRAM BOT OPERATSIYA (/ops) =====
# Bot ichidan harajat/kirim/o'tkazma kirityish uchun PIN kod
# Faqat OPS_CHAT_IDS (app/bot/config.py) dagi foydalanuvchilar ishlata oladi.
# BOT_ADMIN_PIN=1234
# BOT_PIN_SESSION_HOURS=12  # PIN sessiyasi soat

# ===== AUDIT WATCHDOG (activity pulse) =====
# Har 10 daqiqada shubhasiz hodisalarni bundle qilib @elya_classic ga yuborish
# AUDIT_NOTIFY_ALL=1   # 0 qilsa faqat ogohlantirishlar
# AUDIT_ENABLED=1      # 0 qilsa audit butunlay o'chadi

# ========== TELEGRAM BOT (hisobot bot - app/bot/main.py) ==========
# BotFather dan olingan token (@BotFather -> /newbot)
# Bu MAJBURIY — env yo'q bo'lsa hisobot bot ishlamaydi
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ========== TELEGRAM CHAT BOT (app/utils/telegram_bot.py) ==========
# Ixtiyoriy — agar alohida ichki chat bot ishlatsangiz, yoqing
# TELEGRAM_CHAT_BOT_TOKEN=

# ========== HIKVISION DOMOFON (davomat) ==========
# Asosiy davomat qurilmasi (kassa va omborxona)
HIKVISION_HOST=192.168.1.199
HIKVISION_PORT=443
HIKVISION_USERNAME=admin
# Parol majburiy — env yo'q bo'lsa davomat sync ishlamaydi
HIKVISION_PASSWORD=your-hikvision-password
# SSL sertifikat tekshiruvi — 0 (default, self-signed uchun) yoki 1 (strict, CA signed bo'lsa)
# LAN ichidagi self-signed kamera uchun 0 qoldirish mumkin
HIKVISION_SSL_VERIFY=0

# ========== XARITA API ==========
# Xarita provayderi: yandex yoki google
# MAP_PROVIDER=yandex

# Yandex Maps: https://developer.tech.yandex.ru/ (ixtiyoriy)
# YANDEX_MAPS_API_KEY=your-yandex-api-key

# Google Maps (MAP_PROVIDER=google bo'lsa)
# GOOGLE_MAPS_API_KEY=your-google-api-key

# ========== CORS (ixtiyoriy, vergul bilan ajrating) ==========
# CORS_ORIGINS=https://example.com,https://app.example.com

# ========== MA'LUMOTLAR BAZASI ==========
# SQLite default. PostgreSQL uchun:
# DATABASE_URL=postgresql://user:pass@localhost:5432/totli_holva

# ========== ADMIN PAROL (faqat birinchi setup uchun) ==========
# create_admin.py, init_data.py
# ADMIN_DEFAULT_PASSWORD=

# Test skriptlari uchun (test_login.py va boshqalar)
# TEST_ADMIN_PASSWORD=
