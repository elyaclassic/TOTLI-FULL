# Nusxalab .env deb saqlang

TELEGRAM_BOT_TOKEN=

# polling = faqat mahalliy sinov (kompyuter o'chsa bot ham to'xtaydi)
# webhook = bulut server — kompyuter o'chsa ham ishlaydi (HTTPS URL kerak)
BOT_MODE=polling

# --- Webhook (BOT_MODE=webhook bo'lsa majburiy) ---
# Masalan: https://sizning-app.onrender.com  (oxirida / qo'ymang)
WEBHOOK_BASE_URL=
# POST yo'l (o'zgartirmasangiz bo'ladi)
WEBHOOK_PATH=/webhook/telegram
# Tasodifiy uzun qator (xavfsizlik). Bo'sh qoldirish mumkin, lekin tavsiya etiladi.
WEBHOOK_SECRET=

# Server (Docker / Render / Fly — odatda PORT avtomatik)
HOST=0.0.0.0
PORT=8080

# Polling: bir mashinada ikkinchi botni ishga tushirmaslik (standart port 47891)
# BOT_LOCK_PORT=47891

OPENAI_API_KEY=
# Whisper: uz, ru, ...  yoki bo'sh = tilni avtomatik topish
WHISPER_LANGUAGE=uz

# Google: service account JSON yo'li; jadvalni JSON ichidagi client_email bilan ulashing
GOOGLE_SHEETS_CREDENTIALS_JSON=
# Spreadsheet URL: /d/BU_YERDA_ID/
GOOGLE_SHEET_ID=
GOOGLE_SHEET_WORKSHEET=Sheet1
